diff --git a/src/app/api/public/v1/queries/route.ts b/src/app/api/public/v1/queries/route.ts
new file mode 100644
index 0000000..1b13102
--- /dev/null
+++ b/src/app/api/public/v1/queries/route.ts
@@ -0,0 +1,188 @@
+import { NextResponse } from 'next/server'
+import { z } from 'zod'
+import {
+  authenticateApiKey,
+  requireScope,
+  logApiRequest,
+  getClientIp,
+  rateLimitHeaders,
+} from '@/lib/api-auth'
+import { db } from '@/lib/db'
+import { executeSelectQuery } from '@/lib/sqlite'
+import { validateSQLQuery, sanitizeSQL } from '@/lib/sql-security'
+
+/**
+ * POST /api/public/v1/queries
+ *
+ * Executes a read-only SQL SELECT against one of the API key owner's data
+ * sources. Requires the `execute` scope.
+ *
+ * Body:
+ *   { dataSourceId: string, sql: string, limit?: number }
+ *
+ * The `limit` (default 1000, max 10000) is appended to the query if the SQL
+ * doesn't already contain LIMIT — protects against accidental huge result
+ * sets from integration tools.
+ *
+ * Response:
+ *   { data: Row[], columns: string[], rowCount: number, executionTime: number }
+ */
+const querySchema = z.object({
+  dataSourceId: z.string().min(1),
+  sql: z.string().trim().min(1, 'SQL is required').max(20_000),
+  limit: z.number().int().min(1).max(10_000).optional().default(1000),
+})
+
+export async function POST(req: Request) {
+  const startedAt = Date.now()
+  const endpoint = '/api/public/v1/queries'
+  const method = 'POST'
+
+  const auth = await authenticateApiKey(req)
+  if (!auth.ok) {
+    return NextResponse.json(
+      { error: auth.error },
+      { status: auth.status, headers: rateLimitHeaders(auth) },
+    )
+  }
+
+  try {
+    requireScope(auth, 'execute')
+  } catch (err) {
+    const status = (err as Error & { statusCode?: number }).statusCode ?? 403
+    logApiRequest({
+      apiKeyId: auth.apiKey.id,
+      endpoint,
+      method,
+      statusCode: status,
+      durationMs: Date.now() - startedAt,
+      ip: getClientIp(req),
+    })
+    return NextResponse.json(
+      { error: (err as Error).message },
+      { status, headers: rateLimitHeaders(auth) },
+    )
+  }
+
+  let rowCount = 0
+  try {
+    const body = await req.json().catch(() => null)
+    const parsed = querySchema.safeParse(body)
+    if (!parsed.success) {
+      logApiRequest({
+        apiKeyId: auth.apiKey.id,
+        endpoint,
+        method,
+        statusCode: 400,
+        durationMs: Date.now() - startedAt,
+        ip: getClientIp(req),
+      })
+      return NextResponse.json(
+        { error: 'Validation failed', issues: parsed.error.issues },
+        { status: 400, headers: rateLimitHeaders(auth) },
+      )
+    }
+
+    const { dataSourceId, sql, limit } = parsed.data
+
+    // Fetch the datasource and verify ownership
+    const datasource = await db.dataSource.findUnique({
+      where: { id: dataSourceId },
+      select: { id: true, userId: true, filePath: true, name: true, status: true },
+    })
+
+    if (!datasource || datasource.userId !== auth.user.id) {
+      logApiRequest({
+        apiKeyId: auth.apiKey.id,
+        endpoint,
+        method,
+        statusCode: 404,
+        durationMs: Date.now() - startedAt,
+        ip: getClientIp(req),
+      })
+      return NextResponse.json(
+        { error: 'Data source not found' },
+        { status: 404, headers: rateLimitHeaders(auth) },
+      )
+    }
+
+    if (datasource.status !== 'ready') {
+      logApiRequest({
+        apiKeyId: auth.apiKey.id,
+        endpoint,
+        method,
+        statusCode: 409,
+        durationMs: Date.now() - startedAt,
+        ip: getClientIp(req),
+      })
+      return NextResponse.json(
+        { error: `Data source is not ready (status: ${datasource.status})` },
+        { status: 409, headers: rateLimitHeaders(auth) },
+      )
+    }
+
+    // Validate the SQL — only safe SELECT statements are allowed
+    const validation = validateSQLQuery(sql)
+    if (!validation.isSafe) {
+      logApiRequest({
+        apiKeyId: auth.apiKey.id,
+        endpoint,
+        method,
+        statusCode: 400,
+        durationMs: Date.now() - startedAt,
+        ip: getClientIp(req),
+      })
+      return NextResponse.json(
+        { error: 'Query validation failed', details: validation.errors },
+        { status: 400, headers: rateLimitHeaders(auth) },
+      )
+    }
+
+    // Inject a LIMIT if none is present, to protect integration tools from
+    // accidentally pulling millions of rows.
+    const sanitized = sanitizeSQL(sql)
+    const finalSql = /\blimit\b/i.test(sanitized)
+      ? sanitized
+      : `${sanitized} LIMIT ${limit}`
+
+    const result = executeSelectQuery(datasource.filePath, finalSql)
