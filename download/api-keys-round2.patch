diff --git a/src/app/api/settings/api-keys/usage/route.ts b/src/app/api/settings/api-keys/usage/route.ts
new file mode 100644
index 0000000..f1887fb
--- /dev/null
+++ b/src/app/api/settings/api-keys/usage/route.ts
@@ -0,0 +1,119 @@
+import { NextResponse } from 'next/server'
+import { getCurrentUser } from '@/lib/auth-utils'
+import { db } from '@/lib/db'
+import { maskApiKey } from '@/lib/api-auth'
+
+/**
+ * GET /api/settings/api-keys/usage
+ *
+ * Returns 7-day usage breakdown per active API key for the current user.
+ * Used by the manager's per-key sparkline + the aggregate usage chart.
+ *
+ * Response:
+ *   {
+ *     range: { start, end, days: 7 },
+ *     keys: [{
+ *       id, label, maskedKey,
+ *       total: number,
+ *       byDay: [{ date: 'YYYY-MM-DD', count, avgMs, errors }],
+ *       topEndpoints: [{ endpoint, count }]
+ *     }],
+ *     aggregate: { total, byDay: [{ date, count }] }
+ *   }
+ */
+export async function GET() {
+  try {
+    const user = await getCurrentUser()
+    if (!user) {
+      return NextResponse.json({ error: 'Not authenticated' }, { status: 401 })
+    }
+
+    const days = 7
+    const end = new Date()
+    const start = new Date(end.getTime() - days * 24 * 60 * 60 * 1000)
+
+    const keys = await db.apiKey.findMany({
+      where: { userId: user.id },
+      orderBy: { createdAt: 'desc' },
+      select: {
+        id: true,
+        label: true,
+        keyPrefix: true,
+        revokedAt: true,
+        requestLogs: {
+          where: { createdAt: { gte: start, lte: end } },
+          select: { endpoint: true, statusCode: true, durationMs: true, createdAt: true },
+        },
+      },
+    })
+
+    // Build per-day buckets
+    const dayBuckets: string[] = []
+    for (let i = 0; i < days; i++) {
+      const d = new Date(start.getTime() + i * 24 * 60 * 60 * 1000)
+      dayBuckets.push(d.toISOString().slice(0, 10))
+    }
+
+    const keysOut = keys.map((k) => {
+      const byDayMap = new Map<string, { count: number; totalMs: number; errors: number }>()
+      const endpointMap = new Map<string, number>()
+      for (const log of k.requestLogs) {
+        const day = log.createdAt.toISOString().slice(0, 10)
+        const entry = byDayMap.get(day) ?? { count: 0, totalMs: 0, errors: 0 }
+        entry.count += 1
+        entry.totalMs += log.durationMs
+        if (log.statusCode >= 400) entry.errors += 1
+        byDayMap.set(day, entry)
+
+        const ep = endpointMap.get(log.endpoint) ?? 0
+        endpointMap.set(log.endpoint, ep + 1)
+      }
+
+      const byDay = dayBuckets.map((date) => {
+        const e = byDayMap.get(date)
+        return {
+          date,
+          count: e?.count ?? 0,
+          avgMs: e && e.count > 0 ? Math.round(e.totalMs / e.count) : 0,
+          errors: e?.errors ?? 0,
+        }
+      })
+
+      const total = k.requestLogs.length
+      const topEndpoints = [...endpointMap.entries()]
+        .map(([endpoint, count]) => ({ endpoint, count }))
+        .sort((a, b) => b.count - a.count)
+        .slice(0, 5)
+
+      return {
+        id: k.id,
+        label: k.label,
+        maskedKey: maskApiKey(k.keyPrefix),
+        revoked: !!k.revokedAt,
+        total,
+        byDay,
+        topEndpoints,
+      }
+    })
+
+    // Aggregate across all keys
+    const aggregateByDay = dayBuckets.map((date) => {
+      let count = 0
+      for (const k of keysOut) {
+        const e = k.byDay.find((d) => d.date === date)
+        if (e) count += e.count
+      }
+      return { date, count }
+    })
+    const aggregateTotal = keysOut.reduce((s, k) => s + k.total, 0)
+
+    return NextResponse.json({
+      range: { start: start.toISOString(), end: end.toISOString(), days },
+      keys: keysOut,
+      aggregate: { total: aggregateTotal, byDay: aggregateByDay },
+    })
+  } catch (error) {
+    console.error('[api-keys/usage] GET error:', error)
+    return NextResponse.json({ error: 'Failed to fetch usage' }, { status: 500 })
+  }
+}
