@@ -0,0 +1,126 @@
+import { NextResponse } from 'next/server'
+import {
+  authenticateApiKey,
+  requireScope,
+  logApiRequest,
+  getClientIp,
+  rateLimitHeaders,
+} from '@/lib/api-auth'
+import { db } from '@/lib/db'
+
+/**
+ * GET /api/public/v1/dashboards
+ *
+ * Lists the API key owner's dashboards with their widget layout.
+ * Requires the `read` scope.
+ *
+ * Response:
+ *   {
+ *     dashboards: [{
+ *       id, name, description, createdAt,
+ *       widgets: [{ id, title, widgetType, sqlQuery, positionX, positionY, width, height }]
+ *     }]
+ *   }
+ */
+export async function GET(req: Request) {
+  const startedAt = Date.now()
+  const endpoint = '/api/public/v1/dashboards'
+  const method = 'GET'
+
+  const auth = await authenticateApiKey(req)
+  if (!auth.ok) {
+    return NextResponse.json(
+      { error: auth.error },
+      { status: auth.status, headers: rateLimitHeaders(auth) },
+    )
+  }
+
+  try {
+    requireScope(auth, 'read')
+  } catch (err) {
+    const status = (err as Error & { statusCode?: number }).statusCode ?? 403
+    logApiRequest({
+      apiKeyId: auth.apiKey.id,
+      endpoint,
+      method,
+      statusCode: status,
+      durationMs: Date.now() - startedAt,
+      ip: getClientIp(req),
+    })
+    return NextResponse.json(
+      { error: (err as Error).message },
+      { status, headers: rateLimitHeaders(auth) },
+    )
+  }
+
+  try {
+    const dashboards = await db.dashboard.findMany({
+      where: { userId: auth.user.id },
+      orderBy: { createdAt: 'desc' },
+      select: {
+        id: true,
+        name: true,
+        description: true,
+        createdAt: true,
+        widgets: {
+          select: {
+            id: true,
+            title: true,
+            widgetType: true,
+            dataSourceId: true,
+            sqlQuery: true,
+            positionX: true,
+            positionY: true,
+            width: true,
+            height: true,
+          },
+          orderBy: { positionY: 'asc' },
+        },
+      },
+    })
+
+    const durationMs = Date.now() - startedAt
+    logApiRequest({
+      apiKeyId: auth.apiKey.id,
+      endpoint,
+      method,
+      statusCode: 200,
+      durationMs,
+      ip: getClientIp(req),
+    })
+
+    return NextResponse.json(
+      {
+        dashboards: dashboards.map((d) => ({
+          id: d.id,
+          name: d.name,
+          description: d.description,
+          createdAt: d.createdAt,
+          widgets: d.widgets.map((w) => ({
+            id: w.id,
+            title: w.title,
+            widgetType: w.widgetType,
+            dataSourceId: w.dataSourceId,
+            sqlQuery: w.sqlQuery,
+            position: { x: w.positionX, y: w.positionY, w: w.width, h: w.height },
+          })),
+        })),
+      },
+      { headers: rateLimitHeaders(auth) },
+    )
+  } catch (err) {
+    console.error('[public/v1/dashboards] handler error:', err)
+    logApiRequest({
+      apiKeyId: auth.apiKey.id,
+      endpoint,
+      method,
+      statusCode: 500,
+      durationMs: Date.now() - startedAt,
+      ip: getClientIp(req),
+    })
+    return NextResponse.json(
+      { error: 'Internal server error' },
+      { status: 500, headers: rateLimitHeaders(auth) },
+    )
+  }
+}
