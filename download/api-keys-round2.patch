+
+/**
+ * Basic client-side validation for an IP address or CIDR range.
+ * Accepts:
+ *   - IPv4: 1.2.3.4
+ *   - IPv4 CIDR: 1.2.3.0/24
+ *   - IPv6: 2001:db8::1
+ *   - IPv6 CIDR: 2001:db8::/32
+ */
+export function isValidIpOrCidr(input: string): boolean {
+  const s = input.trim()
+  if (!s) return false
+  // CIDR?
+  if (s.includes('/')) {
+    const [base, bits] = s.split('/')
+    const bitsNum = parseInt(bits ?? '', 10)
+    if (isNaN(bitsNum)) return false
+    if (base?.includes(':')) {
+      // IPv6 CIDR
+      return bitsNum >= 0 && bitsNum <= 128 && isValidIpv6(base)
+    }
+    // IPv4 CIDR
+    return bitsNum >= 0 && bitsNum <= 32 && isValidIpv4(base ?? '')
+  }
+  if (s.includes(':')) return isValidIpv6(s)
+  return isValidIpv4(s)
+}
+
+function isValidIpv4(s: string): boolean {
+  const parts = s.split('.')
+  if (parts.length !== 4) return false
+  return parts.every((p) => {
+    const n = parseInt(p, 10)
+    return /^\d+$/.test(p) && n >= 0 && n <= 255
+  })
+}
+
+function isValidIpv6(s: string): boolean {
+  // Very permissive — just check it has colons and valid hex groups
+  if (!s.includes(':')) return false
+  const parts = s.split('::')
+  if (parts.length > 2) return false
+  const groups = s.replace('::', ':').split(':').filter(Boolean)
+  return groups.every((g) => /^[0-9a-fA-F]{1,4}$/.test(g))
+}
