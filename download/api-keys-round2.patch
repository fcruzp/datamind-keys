+/// Audit trail for management actions on API keys (create / edit / revoke).
+/// Used for compliance + debugging integration breakages ("who revoked the OpenFN key at 3am?").
+model SettingsAuditLog {
+  id          String   @id @default(cuid())
+  userId      String   @map("user_id")
+  /// "api_key.create" | "api_key.update" | "api_key.revoke"
+  action      String
+  /// Target API key id (null only if action target was unknown)
+  apiKeyId    String?  @map("api_key_id")
+  /// Target API key label (denormalized for human-readable audit even after key is deleted)
+  apiKeyLabel String?  @map("api_key_label")
+  /// JSON snapshot of the change. For create: full new record (minus hash).
+  /// For update: { before: {...}, after: {...} }. For revoke: { revokedAt }.
+  diff        String   @default("{}")
+  ip          String?
+  userAgent   String?  @map("user_agent")
+  createdAt   DateTime @default(now()) @map("created_at")
+
+  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
+  apiKey      ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
+
+  @@index([userId, createdAt])
+  @@index([apiKeyId])
+  @@index([action])
+  @@map("settings_audit_logs")
+}
+
 model ApiRequestLog {
   id          String   @id @default(cuid())
   apiKeyId    String   @map("api_key_id")
