+              <p className="text-[11px] text-muted-foreground/70 italic">
+                {t('ipEmpty')}
+              </p>
+            )}
+          </div>
+
+          {/* Rate limit */}
+          <div className="space-y-2">
+            <div className="flex items-center gap-1.5">
+              <Gauge className="h-3.5 w-3.5 text-amber-600" />
+              <Label className="text-sm">{t('rateLimit')}</Label>
+            </div>
+            <div className="flex gap-2">
+              <Select
+                value={rateMode}
+                onValueChange={(v) => setRateMode(v as 'default' | 'custom')}
+              >
+                <SelectTrigger className="bg-background w-[140px]">
+                  <SelectValue />
+                </SelectTrigger>
+                <SelectContent>
+                  <SelectItem value="default">{t('rateLimitDefault')}</SelectItem>
