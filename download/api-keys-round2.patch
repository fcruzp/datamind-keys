+import { NextResponse } from 'next/server'
+import { getCurrentUser } from '@/lib/auth-utils'
+import { db } from '@/lib/db'
+import { maskApiKey, parseScopes, parseAllowedIps } from '@/lib/api-auth'
+
+/**
+ * GET /api/settings/api-keys/revoked
+ *
+ * Returns revoked API keys + the full audit trail of management actions
+ * (create / update / revoke) for the current user. Used by the UI's
+ * "Audit & revoked keys" panel.
+ *
+ * Response:
+ *   {
+ *     revokedKeys: [{ id, label, maskedKey, scopes, revokedAt, createdAt, lastUsedAt }],
+ *     auditLog: [{ id, action, apiKeyLabel, diff, ip, createdAt }]
+ *   }
+ */
+export async function GET() {
+  try {
+    const user = await getCurrentUser()
+    if (!user) {
+      return NextResponse.json({ error: 'Not authenticated' }, { status: 401 })
+    }
+
+    const [revokedKeys, auditLog] = await Promise.all([
+      db.apiKey.findMany({
+        where: { userId: user.id, revokedAt: { not: null } },
+        orderBy: { revokedAt: 'desc' },
+        select: {
+          id: true,
+          label: true,
+          keyPrefix: true,
+          scopes: true,
+          allowedIps: true,
+          revokedAt: true,
+          lastUsedAt: true,
+          lastUsedIp: true,
+          createdAt: true,
+          _count: { select: { requestLogs: true } },
+        },
+      }),
+      db.settingsAuditLog.findMany({
+        where: { userId: user.id },
+        orderBy: { createdAt: 'desc' },
+        take: 50, // cap to the most recent 50 entries
+        select: {
+          id: true,
+          action: true,
+          apiKeyId: true,
+          apiKeyLabel: true,
+          diff: true,
+          ip: true,
+          userAgent: true,
+          createdAt: true,
+        },
+      }),
+    ])
+
+    return NextResponse.json({
+      revokedKeys: revokedKeys.map((k) => ({
+        id: k.id,
+        label: k.label,
+        maskedKey: maskApiKey(k.keyPrefix),
+        scopes: parseScopes(k.scopes),
+        allowedIps: parseAllowedIps(k.allowedIps),
+        revokedAt: k.revokedAt,
+        lastUsedAt: k.lastUsedAt,
+        lastUsedIp: k.lastUsedIp,
+        createdAt: k.createdAt,
+        requestCount: k._count.requestLogs,
+      })),
+      auditLog: auditLog.map((e) => ({
+        id: e.id,
+        action: e.action,
+        apiKeyId: e.apiKeyId,
+        apiKeyLabel: e.apiKeyLabel,
+        diff: safeParseJson(e.diff),
+        ip: e.ip,
+        userAgent: e.userAgent,
+        createdAt: e.createdAt,
+      })),
+    })
+  } catch (error) {
+    console.error('[api-keys/revoked] GET error:', error)
+    return NextResponse.json({ error: 'Failed to fetch audit trail' }, { status: 500 })
+  }
+}
+
+function safeParseJson(s: string): unknown {
+  try {
+    return JSON.parse(s)
+  } catch {
+    return {}
+  }
+}
