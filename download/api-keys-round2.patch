+                {ipError}
+              </p>
+            )}
+            {allowedIps.length > 0 ? (
+              <div className="flex flex-wrap gap-1.5">
+                {allowedIps.map((ip) => (
+                  <Badge
+                    key={ip}
+                    variant="outline"
+                    className="font-mono text-[11px] gap-1 bg-sky-500/5 border-sky-500/20 text-sky-700 dark:text-sky-300 pl-2 pr-1 py-0.5"
+                  >
+                    {ip}
+                    <button
