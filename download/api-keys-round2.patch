+// ─── Edit dialog ─────────────────────────────────────────────
+
+interface EditApiKeyDialogProps {
+  open: boolean;
+  onOpenChange: (open: boolean) => void;
+  locale: Locale;
+  keyView: ApiKeyView;
+  onSaved: () => void;
+}
+
+function EditApiKeyDialog({
+  open,
+  onOpenChange,
+  locale,
+  keyView,
+  onSaved,
+}: EditApiKeyDialogProps) {
+  const t = getDict(locale);
+  const metas = scopeMeta(locale, t);
+
+  const [label, setLabel] = useState(keyView.label);
+  const [scopes, setScopes] = useState<ApiScope[]>(keyView.scopes);
+  const [allowedIps, setAllowedIps] = useState<string[]>(keyView.allowedIps);
+  const [ipInput, setIpInput] = useState('');
+  const [ipError, setIpError] = useState<string | null>(null);
+  const [rateMode, setRateMode] = useState<'default' | 'custom'>(
+    keyView.rateLimitPerMinute === null ? 'default' : 'custom',
+  );
+  const [rateValue, setRateValue] = useState(
+    keyView.rateLimitPerMinute === null ? '' : String(keyView.rateLimitPerMinute),
+  );
+  const [saving, setSaving] = useState(false);
+  const [error, setError] = useState<string | null>(null);
+
+  function toggleScope(scope: ApiScope) {
+    setError(null);
+    setScopes((prev) => {
+      if (prev.includes(scope)) {
+        const next = prev.filter((s) => s !== scope);
+        return next.length === 0 ? prev : next;
+      }
+      return [...prev, scope];
+    });
+  }
+
+  function addIp() {
+    const v = ipInput.trim();
+    if (!v) return;
+    if (!isValidIpOrCidr(v)) {
+      setIpError(t('ipInvalid'));
+      return;
+    }
+    if (allowedIps.includes(v)) {
+      setIpInput('');
+      return;
+    }
+    setAllowedIps([...allowedIps, v]);
+    setIpInput('');
+    setIpError(null);
+  }
+
+  function removeIp(ip: string) {
+    setAllowedIps(allowedIps.filter((x) => x !== ip));
+  }
+
+  async function handleSubmit(e: React.FormEvent) {
+    e.preventDefault();
+    if (saving) return;
+    if (!label.trim()) {
+      setError(t('labelField') + ' is required.');
+      return;
+    }
+    if (scopes.length === 0) {
+      setError(t('selectScope'));
+      return;
+    }
+
+    const rateLimitPerMinute =
+      rateMode === 'custom' ? parseInt(rateValue, 10) || null : null;
+    if (rateMode === 'custom' && (isNaN(rateLimitPerMinute as number) || (rateLimitPerMinute as number) < 1 || (rateLimitPerMinute as number) > 1000)) {
+      setError(t('rateLimit') + ': 1–1000');
+      return;
+    }
+
+    setSaving(true);
+    setError(null);
+
+    try {
+      const res = await authFetch(`/api/settings/api-keys/${keyView.id}`, {
+        method: 'PATCH',
+        headers: { 'content-type': 'application/json' },
+        body: JSON.stringify({
+          label: label.trim(),
+          scopes,
+          allowedIps,
+          rateLimitPerMinute,
+        }),
+      });
+      const data = await res.json().catch(() => ({}));
+      if (!res.ok) {
+        setError(data?.error || t('editError'));
+        return;
+      }
+      toast.success(t('keyUpdated'));
+      onSaved();
+      onOpenChange(false);
+    } catch {
+      setError(t('editError'));
+    } finally {
+      setSaving(false);
+    }
+  }
+
+  return (
+    <Dialog open={open} onOpenChange={onOpenChange}>
+      <DialogContent className="sm:max-w-md p-0 gap-0 bg-background/95 backdrop-blur-xl border-border/30 shadow-2xl max-h-[90vh] overflow-y-auto">
+        <DialogHeader className="px-6 pt-6 pb-4 shrink-0">
+          <DialogTitle className="flex items-center gap-2">
+            <Pencil className="h-5 w-5 text-emerald-600" />
+            {t('editKey')}
+          </DialogTitle>
+          <DialogDescription className="text-xs leading-relaxed pt-1">
+            {t('editKeyDesc')}
+          </DialogDescription>
+        </DialogHeader>
+
+        <form onSubmit={handleSubmit} className="px-6 pb-6 space-y-5">
+          {/* Label */}
+          <div className="space-y-1.5">
+            <Label htmlFor="edit-api-key-label" className="text-sm">
+              {t('labelField')}
+            </Label>
+            <Input
+              id="edit-api-key-label"
+              value={label}
+              onChange={(e) => {
+                setLabel(e.target.value);
+                setError(null);
+              }}
+              maxLength={60}
+              className="bg-background"
+            />
+          </div>
+
+          {/* Scopes */}
+          <div className="space-y-2">
+            <Label className="text-sm">{t('scopes')}</Label>
+            <div className="space-y-2">
+              {metas.map((meta) => {
+                const checked = scopes.includes(meta.id);
+                return (
+                  <label
+                    key={meta.id}
+                    htmlFor={`edit-scope-${meta.id}`}
