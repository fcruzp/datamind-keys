+'use client';
+
+import { useMemo } from 'react';
+import type { UsageDayBucket } from './dict';
+
+interface UsageChartProps {
+  /** Per-day buckets (7 entries for the last week). */
+  data: UsageDayBucket[];
+  /** Width of the chart area in px. */
+  width?: number;
+  /** Height of the chart area in px. */
+  height?: number;
+}
+
+/**
+ * A tiny, dependency-free SVG sparkline showing the last-7-days request
+ * volume for a single API key. Renders inline inside the key card.
+ *
+ * - Bars are emerald by default, amber on error-heavy days, empty days render
+ *   as a faint baseline tick so the chart never looks broken.
+ * - Tooltip-on-hover is intentionally omitted to keep the component cheap;
+ *   the per-day counts are already shown in the usage panel.
+ */
+export function UsageChart({ data, width = 140, height = 32 }: UsageChartProps) {
+  const { bars, maxValue } = useMemo(() => {
+    const max = Math.max(1, ...data.map((d) => d.count));
+    const barWidth = width / data.length;
+    const bars = data.map((d, i) => {
+      const ratio = d.count / max;
+      const barHeight = Math.max(2, ratio * (height - 4));
+      const x = i * barWidth + barWidth * 0.15;
+      const y = height - barHeight - 1;
+      const w = barWidth * 0.7;
+      const errorHeavy = d.errors > 0 && d.errors >= d.count * 0.5;
+      return { x, y, w, h: barHeight, count: d.count, errorHeavy };
+    });
+    return { bars, maxValue: max };
+  }, [data, width, height]);
+
+  if (maxValue === 0) {
+    return (
+      <div
+        className="flex items-center justify-center text-[10px] text-muted-foreground/60 italic"
+        style={{ width, height }}
+      >
+        no requests
+      </div>
+    );
+  }
+
+  return (
+    <svg
+      width={width}
+      height={height}
+      viewBox={`0 0 ${width} ${height}`}
+      className="overflow-visible"
+      role="img"
