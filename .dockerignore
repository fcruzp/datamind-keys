# =============================================================================
# .dockerignore — files NOT copied into the Docker build context
# =============================================================================
# Keeping the context small = faster builds + smaller image

# Version control
.git
.gitignore
.gitattributes

# Dependencies (reinstalled inside the image)
node_modules
.pnp
.pnp.js
bun.lockb

# Next.js build output (rebuilt inside the image)
.next
out
build
dist

# Sandbox-only artefacts
db
*.db
*.db-journal
dev.log
server.log
*.log
download
tool-results
scripts/test-api-keys.sh
examples
CONTRIBUTING.md

# Local env files (production env is injected by Coolify)
.env
.env.*
!.env.production.example

# Docker meta
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.*.yml
coolify.yaml

# Editor / OS noise
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db

# Coolify / CI
.coolify
.github

# Prisma migration history (we apply migrations via Supabase Studio / psql,
# not at container start — schema is shared with BIweb)
prisma/migrations
