# ── Postgres (Supabase pooler) — NECESARIO para Prisma ─────────────────────
# Dashboard → Project Settings → Database → Connection string
# Sustituye [PASSWORD] por la contraseña del rol postgres.
#
# DATABASE_URL = Transaction pooler (puerto 6543, pgbouncer=true) → runtime
# DIRECT_URL   = Session/direct pooler (puerto 5432)              → migraciones
#
# Ejemplo (región us-east-1):
# DATABASE_URL=postgresql://postgres.rsrcdaepiwjqfynwwzcn:MiPassword@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.rsrcdaepiwjqfynwwzcn:MiPassword@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.rsrcdaepiwjqfynwwzcn:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.rsrcdaepiwjqfynwwzcn:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── App ────────────────────────────────────────────────────────────────────
# URL pública del sitio (para redirects de Supabase Auth)
NEXT_PUBLIC_SITE_URL=https://datamind-api.mooo.com

# ── Opcional: límites de rate-limit global (default 60/min por key) ─────────
# RATE_LIMIT_DEFAULT_PER_MINUTE=60
