# =============================================================================
# DataMind BI — API Keys Manager
# Variables de entorno para PRODUCCIÓN (Coolify)
# =============================================================================
# El Dockerfile ya tiene "baked-in" las variables PÚBLICAS (anon key, URL de
# Supabase, NEXT_PUBLIC_SITE_URL, etc.) — NO necesitas configurarlas aquí.
#
# Solo necesitas configurar estas 3 variables SECRETAS en Coolify:
#   Service → Environment Variables
# =============================================================================

# ── Supabase (secreta — service role, bypass RLS) ───────────────────────────
# Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJzcmNkYWVwaXdqcWZ5bnd3emNuIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3ODI5OTY4NiwiZXhwIjoyMDkzODc1Njg2fQ.66wKIYj0Y-BC1BTECoRbUebA9wkfrIhz721ACaZ5Dm0

# ── Postgres (secretas — credenciales del rol postgres) ─────────────────────
# Dashboard → Project Settings → Database → Connection string
# Sustituye [PASSWORD] por la contraseña del rol postgres.
#
# DATABASE_URL = Transaction pooler (puerto 6543, pgbouncer=true) → runtime
# DIRECT_URL   = Session/direct pooler (puerto 5432)              → migraciones
#
# Ejemplo (región us-east-1):
# DATABASE_URL=postgresql://postgres.rsrcdaepiwjqfynwwzcn:MiPassword@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.rsrcdaepiwjqfynwwzcn:MiPassword@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.rsrcdaepiwjqfynwwzcn:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.rsrcdaepiwjqfynwwzcn:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres

# =============================================================================
# Variables PÚBLICAS ya en el Dockerfile (NO tocar en Coolify):
#   NODE_ENV=production
#   NEXT_TELEMETRY_DISABLED=1
#   PORT=3000
#   HOSTNAME=0.0.0.0
#   NEXT_PUBLIC_SUPABASE_URL=https://rsrcdaepiwjqfynwwzcn.supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=... (anon, pública por diseño)
#   SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
#   NEXT_PUBLIC_SITE_URL=https://datamind-api.mooo.com
# =============================================================================
