// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//
// ============================================================================
// FULL INTEGRATION with BIweb (datamind.mooo.com)
// ============================================================================
// This schema MIRRORS the existing tables in the shared Supabase project
// (rsrcdaepiwjqfynwwzcn). It does NOT create or alter any table — the tables
// are owned by BIweb. We use @@map / @map to map our Prisma models to the
// existing snake_case table and column names.
//
// The Dockerfile runs ONLY `prisma generate` (never `prisma db push`), so
// this schema is used purely for type generation + query building.
//
// ----------------------------------------------------------------------------
// IMPORTANT — actual column types (verified via information_schema):
// ----------------------------------------------------------------------------
// `users.id`                → text (cuid, app-generated)
// `users.created_at`        → timestamp WITHOUT time zone
// `users.updated_at`        → timestamp WITHOUT time zone (no default)
// `api_keys.id`             → uuid (gen_random_uuid)
// `api_keys.user_id`        → uuid → references auth.users.id (= users.supabase_id)
//                             ⚠ NOT users.id (text). So we pass supabaseId.
// `api_keys.scopes`         → jsonb default '[]'
// `api_keys.allowed_ips`    → jsonb default '[]' (NOT NULL — must be provided!)
// `api_keys.rate_limit_per_minute` → integer nullable
// `api_keys.last_used_ip`   → inet
// `api_keys.revoked_at`     → timestamptz
// `api_keys.last_used_at`   → timestamptz
// `api_keys.expires_at`     → timestamptz
// `api_keys.created_at`     → timestamptz
// `api_request_logs.id`     → uuid
// `api_request_logs.api_key_id` → uuid
// `api_request_logs.ip`     → inet
// `api_request_logs.created_at` → timestamptz
//
// Because users.id (text) and api_keys.user_id (uuid) have DIFFERENT types,
// there is NO Prisma relation between User ↔ ApiKey. We resolve the user
// from an API key by looking up `users.supabase_id = api_keys.user_id`
// (a separate query).
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===========================================================================
// User — mirrors BIweb's `users` table (NOT auth.users).
// In BIweb, this row is created on signup via a trigger. The `supabaseId`
// field links to auth.users.id (the Supabase Auth UUID).
//
// NOTE: `users.id` is a text/cuid — it is NOT used as the foreign key for
// `api_keys.user_id` (which is a uuid referencing auth.users.id). Use
// `users.supabaseId` for that.
// ===========================================================================
model User {
  id                  String   @id @default(cuid())
  supabaseId          String   @unique @map("supabase_id")
  email               String   @unique
  name                String?
  avatarUrl           String?  @map("avatar_url")
  company             String?
  phone               String?
  role                String   @default("user") // admin, user
  country             String?
  taxId               String?  @map("tax_id")
  preferredLang       String   @default("es") @map("preferred_lang")
  openRouterKey       String?  @map("open_router_key")
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  interestArea        String?  @map("interest_area")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp

  @@map("users")
}

// ===========================================================================
// ApiKey — mirrors BIweb's `api_keys` table.
//
// IMPORTANT: `userId` is a uuid that references auth.users.id (= users.supabase_id),
// NOT users.id (text/cuid). When creating an API key, pass user.supabaseId
// as the `userId`, NOT user.id.
//
// There is NO Prisma relation between ApiKey ↔ User because the column
// types differ (uuid vs text). The user is resolved via a separate
// `db.user.findUnique({ where: { supabaseId: apiKey.userId } })` query.
// ===========================================================================
model ApiKey {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  keyHash            String    @unique @map("key_hash")
  keyPrefix          String    @map("key_prefix")
  label              String
  scopes             Json      @default("[]")
  allowedIps         Json      @default("[]") @map("allowed_ips")
  rateLimitPerMinute Int?      @map("rate_limit_per_minute")
  revokedAt          DateTime? @map("revoked_at") @db.Timestamptz
  lastUsedAt         DateTime? @map("last_used_at") @db.Timestamptz
  lastUsedIp         String?   @map("last_used_ip") @db.Inet
  expiresAt          DateTime? @map("expires_at") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

// ===========================================================================
// ApiRequestLog — mirrors BIweb's `api_request_logs` table.
//
// `apiKeyId` is a uuid (matches api_keys.id which is now uuid). There is no
// Prisma relation because the schema intentionally avoids FK enforcement at
// the Prisma layer (BIweb's table doesn't define an actual FK constraint
// between these two tables).
// ===========================================================================
model ApiRequestLog {
  id         String   @id @default(uuid()) @db.Uuid
  apiKeyId   String   @map("api_key_id") @db.Uuid
  endpoint   String
  method     String
  statusCode Int      @map("status_code")
  durationMs Int      @map("duration_ms")
  rowCount   Int?     @map("row_count")
  ip         String?  @db.Inet
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([apiKeyId, createdAt])
  @@index([createdAt])
  @@map("api_request_logs")
}

// ===========================================================================
// SettingsAuditLog — mirrors the `settings_audit_logs` table.
// This table is NOT in BIweb's Prisma schema; it was created by our
// supabase/migrations/0001_schema_additions.sql. It uses native Postgres
// types (uuid, jsonb, inet, timestamptz) so we use @db modifiers.
//
// IMPORTANT: `user_id` references auth.users(id) — the Supabase Auth UUID,
// NOT users.id (cuid). When writing audit entries, pass the Supabase UUID
// (SessionUser.supabaseId), not the Prisma User.id.
//
// `api_key_id` is now a uuid (matches api_keys.id which is now uuid), so
// callers CAN pass the API key's id when writing audit entries.
// ===========================================================================
model SettingsAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  action      String
  apiKeyId    String?  @map("api_key_id") @db.Uuid
  apiKeyLabel String?  @map("api_key_label")
  diff        Json     @default("{}")
  ip          String?  @db.Inet
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId, createdAt])
  @@index([apiKeyId])
  @@index([action])
  @@map("settings_audit_logs")
}
