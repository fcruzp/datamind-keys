// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys ApiKey[]
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// API Keys for third-party integrations (OpenFN, N8N, etc.)
model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  keyHash     String    @unique
  keyPrefix   String
  label       String
  scopes      String    @default("[]")
  /// JSON array of allowed IPs/CIDRs. Empty = allow all.
  allowedIps  String    @default("[]")
  /// Per-key rate limit (requests per minute). Null = use global default (60).
  rateLimitPerMinute Int?
  revokedAt   DateTime?
  lastUsedAt  DateTime?
  lastUsedIp  String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestLogs ApiRequestLog[]

  @@index([userId])
  @@index([keyHash])
}

model ApiRequestLog {
  id          String   @id @default(cuid())
  apiKeyId    String
  endpoint    String
  method      String
  statusCode  Int
  durationMs  Int
  rowCount    Int?
  ip          String?
  createdAt   DateTime @default(now())

  apiKey      ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, createdAt])
  @@index([createdAt])
}

/// Audit trail for management actions on API keys (create / edit / revoke).
/// Used to satisfy compliance: "who did what, when".
model SettingsAuditLog {
  id          String   @id @default(cuid())
  userId      String
  /// "api_key.create" | "api_key.update" | "api_key.revoke"
  action      String
  /// Target API key id (null only if action target was unknown)
  apiKeyId    String?
  /// Target API key label (denormalized for human-readable audit even after key is deleted)
  apiKeyLabel String?
  /// JSON snapshot of the change. For create: full new record (minus hash).
  /// For update: { before: {...}, after: {...} }. For revoke: { revokedAt }.
  diff        String   @default("{}")
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([apiKeyId])
  @@index([action])
}
