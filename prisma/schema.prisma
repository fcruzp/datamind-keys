// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//
// ============================================================================
// FULL INTEGRATION with BIweb (datamind.mooo.com)
// ============================================================================
// This schema MIRRORS the existing tables in the shared Supabase project
// (rsrcdaepiwjqfynwwzcn). It does NOT create or alter any table â€” the tables
// are owned by BIweb. We use @@map / @map to map our Prisma models to the
// existing snake_case table and column names.
//
// The Dockerfile runs ONLY `prisma generate` (never `prisma db push`), so
// this schema is used purely for type generation + query building.
//
// ----------------------------------------------------------------------------
// IMPORTANT â€” actual column types (verified via information_schema):
// ----------------------------------------------------------------------------
// `users.id`                â†’ text (cuid, app-generated)
// `users.created_at`        â†’ timestamp WITHOUT time zone
// `users.updated_at`        â†’ timestamp WITHOUT time zone (no default)
// `api_keys.id`             â†’ uuid (gen_random_uuid)
// `api_keys.user_id`        â†’ uuid â†’ references auth.users.id (= users.supabase_id)
//                             âš  NOT users.id (text). So we pass supabaseId.
// `api_keys.scopes`         â†’ jsonb default '[]'
// `api_keys.allowed_ips`    â†’ jsonb default '[]' (NOT NULL â€” must be provided!)
// `api_keys.rate_limit_per_minute` â†’ integer nullable
// `api_keys.last_used_ip`   â†’ inet
// `api_keys.revoked_at`     â†’ timestamptz
// `api_keys.last_used_at`   â†’ timestamptz
// `api_keys.expires_at`     â†’ timestamptz
// `api_keys.created_at`     â†’ timestamptz
// `api_request_logs.id`     â†’ uuid
// `api_request_logs.api_key_id` â†’ uuid
// `api_request_logs.ip`     â†’ inet
// `api_request_logs.created_at` â†’ timestamptz
//
// Because users.id (text) and api_keys.user_id (uuid) have DIFFERENT types,
// there is NO Prisma relation between User â†” ApiKey. We resolve the user
// from an API key by looking up `users.supabase_id = api_keys.user_id`
// (a separate query).
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===========================================================================
// User â€” mirrors BIweb's `users` table (NOT auth.users).
// In BIweb, this row is created on signup via a trigger. The `supabaseId`
// field links to auth.users.id (the Supabase Auth UUID).
//
// NOTE: `users.id` is a text/cuid â€” it is NOT used as the foreign key for
// `api_keys.user_id` (which is a uuid referencing auth.users.id). Use
// `users.supabaseId` for that.
// ===========================================================================
model User {
  id                  String   @id @default(cuid())
  supabaseId          String   @unique @map("supabase_id")
  email               String   @unique
  name                String?
  avatarUrl           String?  @map("avatar_url")
  company             String?
  phone               String?
  role                String   @default("user") // admin, user
  country             String?
  taxId               String?  @map("tax_id")
  preferredLang       String   @default("es") @map("preferred_lang")
  openRouterKey       String?  @map("open_router_key")
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  interestArea        String?  @map("interest_area")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp

  @@map("users")
}

// ===========================================================================
// ApiKey â€” mirrors BIweb's `api_keys` table.
//
// IMPORTANT: `userId` is a uuid that references auth.users.id (= users.supabase_id),
// NOT users.id (text/cuid). When creating an API key, pass user.supabaseId
// as the `userId`, NOT user.id.
//
// There is NO Prisma relation between ApiKey â†” User because the column
// types differ (uuid vs text). The user is resolved via a separate
// `db.user.findUnique({ where: { supabaseId: apiKey.userId } })` query.
// ===========================================================================
model ApiKey {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  keyHash            String    @unique @map("key_hash")
  keyPrefix          String    @map("key_prefix")
  label              String
  scopes             Json      @default("[]")
  allowedIps         Json      @default("[]") @map("allowed_ips")
  rateLimitPerMinute Int?      @map("rate_limit_per_minute")
  revokedAt          DateTime? @map("revoked_at") @db.Timestamptz
  lastUsedAt         DateTime? @map("last_used_at") @db.Timestamptz
  lastUsedIp         String?   @map("last_used_ip") @db.Inet
  expiresAt          DateTime? @map("expires_at") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

// ===========================================================================
// ApiRequestLog â€” mirrors BIweb's `api_request_logs` table.
//
// `apiKeyId` is a uuid (matches api_keys.id which is now uuid). There is no
// Prisma relation because the schema intentionally avoids FK enforcement at
// the Prisma layer (BIweb's table doesn't define an actual FK constraint
// between these two tables).
// ===========================================================================
model ApiRequestLog {
  id         String   @id @default(uuid()) @db.Uuid
  apiKeyId   String   @map("api_key_id") @db.Uuid
  endpoint   String
  method     String
  statusCode Int      @map("status_code")
  durationMs Int      @map("duration_ms")
  rowCount   Int?     @map("row_count")
  ip         String?  @db.Inet
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([apiKeyId, createdAt])
  @@index([createdAt])
  @@map("api_request_logs")
}

// ===========================================================================
// SettingsAuditLog â€” mirrors the `settings_audit_logs` table.
// This table is NOT in BIweb's Prisma schema; it was created by our
// supabase/migrations/0001_schema_additions.sql. It uses native Postgres
// types (uuid, jsonb, inet, timestamptz) so we use @db modifiers.
//
// IMPORTANT: `user_id` references auth.users(id) â€” the Supabase Auth UUID,
// NOT users.id (cuid). When writing audit entries, pass the Supabase UUID
// (SessionUser.supabaseId), not the Prisma User.id.
//
// `api_key_id` is now a uuid (matches api_keys.id which is now uuid), so
// callers CAN pass the API key's id when writing audit entries.
// ===========================================================================
model SettingsAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  action      String
  apiKeyId    String?  @map("api_key_id") @db.Uuid
  apiKeyLabel String?  @map("api_key_label")
  diff        Json     @default("{}")
  ip          String?  @db.Inet
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId, createdAt])
  @@index([apiKeyId])
  @@index([action])
  @@map("settings_audit_logs")
}

// ===========================================================================
// DataSource â€” mirrors BIweb's `data_sources` table.
//
// This is NOT a database-connection table. It stores UPLOADED SQLITE FILES
// (file_name, file_size, file_path, file_type default 'sqlite').
//
// `user_id` is TEXT and references `users.id` (the cuid), NOT auth.users.id.
// Verified empirically: count of data_sources WHERE user_id = users.supabase_id
// â†’ 0; count WHERE user_id = users.id â†’ 1 (for Boceto Perez).
//
// So tenant scoping for this table uses `auth.user.id` (cuid), NOT supabaseId.
// ===========================================================================
model DataSource {
  id           String   @id
  userId       String?  @map("user_id")
  name         String
  fileName     String   @map("file_name")
  fileSize     Int      @map("file_size")
  filePath     String   @map("file_path")
  fileType     String   @default("sqlite") @map("file_type")
  status       String   @default("uploaded")
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt    DateTime @map("updated_at") @db.Timestamp

  @@index([userId])
  @@map("data_sources")
}

// ===========================================================================
// Dashboard â€” mirrors BIweb's `dashboards` table.
//
// `user_id` is TEXT and references `users.id` (the cuid), same convention as
// data_sources. Tenant scoping uses `auth.user.id`.
//
// `layout` is TEXT (stores a JSON string serialized by BIweb's frontend).
// ===========================================================================
model Dashboard {
  id          String   @id
  userId      String?  @map("user_id")
  name        String
  description String?
  layout      String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt   DateTime @map("updated_at") @db.Timestamp

  widgets     DashboardWidget[]

  @@index([userId])
  @@map("dashboards")
}

// ===========================================================================
// DashboardWidget â€” mirrors BIweb's `dashboard_widgets` table.
//
// `dashboard_id` references `dashboards.id` (both text). We define a Prisma
// relation so we can `include: { widgets: true }` on Dashboard queries.
// `data_source_id` is nullable text â€” references data_sources.id when a widget
// is bound to a specific datasource.
// ===========================================================================
model DashboardWidget {
  id            String   @id
  dashboardId   String   @map("dashboard_id")
  title         String
  widgetType    String   @map("widget_type")
  dataSourceId  String?  @map("data_source_id")
  sqlQuery      String?  @map("sql_query")
  visualization String?
  config        String
  positionX     Int      @default(0) @map("position_x")
  positionY     Int      @default(0) @map("position_y")
  width         Int      @default(6)
  height        Int      @default(4)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt     DateTime @map("updated_at") @db.Timestamp

  dashboard     Dashboard @relation(fields: [dashboardId], references: [id])

  @@index([dashboardId])
  @@index([dataSourceId])
  @@map("dashboard_widgets")
}

// ===========================================================================
// QueryHistory â€” mirrors BIweb's `query_histories` table.
//
// Records NLâ†’SQL query execution results. `data_source_id` references
// data_sources.id (text). Tenant scoping is transitive: a query history
// belongs to the user who owns its datasource.
//
// Note: `natural_query`, `sql_query`, and `result_data` are all NOT NULL,
// so we can only create rows when all three are available. The public API
// /queries endpoint does NOT log here (it lacks natural_query + result_data).
// ===========================================================================
model QueryHistory {
  id            String   @id
  dataSourceId  String   @map("data_source_id")
  sessionId     String?  @map("session_id")
  naturalQuery  String   @map("natural_query")
  sqlQuery      String   @map("sql_query")
  resultData    String   @map("result_data")
  rowCount      Int      @default(0) @map("row_count")
  executionTime Int      @default(0) @map("execution_time")
  status        String   @default("success")
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp

  @@index([dataSourceId])
  @@index([createdAt])
  @@map("query_histories")
}

// ===========================================================================
// UserProfile â€” mirrors BIweb's `user_profiles` table.
//
// `user_id` is UUID and references `auth.users.id` (= users.supabase_id).
// This is DIFFERENT from data_sources/dashboards (which use users.id text).
// Tenant scoping uses `auth.user.supabaseId`.
//
// `tenant_name` is the real tenant concept we were missing â€” defaults to
// 'Personal'. This is what /me should return as the user's tenant.
// ===========================================================================
model UserProfile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  tenantName  String   @default("Personal") @map("tenant_name")
  avatarColor String   @default("from-emerald-500 to-teal-600") @map("avatar_color")
  role        String   @default("owner")
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@unique([userId])
  @@index([userId])
  @@map("user_profiles")
}
